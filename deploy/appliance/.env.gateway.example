# Guardian LAN appliance mode
# Copie para um arquivo local, por exemplo:
# cp deploy/appliance/.env.gateway.example deploy/appliance/.env.gateway

POSTGRES_DB=guardian_lan
POSTGRES_USER=postgres
POSTGRES_PASSWORD=guardian_lan_local_2026
DATABASE_URL=postgres://postgres:guardian_lan_local_2026@postgres:5432/guardian_lan?sslmode=disable
NATS_URL=nats://nats:4222

HTTP_ADDR=:8080
EXPECTED_DNS_RESOLVER=adguardhome

ADGUARD_ENABLED=true
ADGUARD_URL=http://adguardhome:3000/control
ADGUARD_USERNAME=admin
ADGUARD_PASSWORD=change-me
ADGUARD_WEB_BIND_IP=127.0.0.1
ADGUARD_DNS_BIND_IP=0.0.0.0

DNS_SOURCE=adguard_file
DNS_ADGUARD_QUERYLOG=/adguard-work/data/querylog.json
DNS_RESOLVER_NAME=adguardhome

DASHBOARD_PORT=80

DISCOVERY_SOURCE=live
DISCOVERY_PING_ENABLED=true
DISCOVERY_FINGERPRINT_ENABLED=true
DISCOVERY_FINGERPRINT_TIMEOUT_MS=180
DISCOVERY_VENDOR_DB=/usr/share/ieee-data/oui.txt

APPLIANCE_MODE=gateway
APPLIANCE_WAN_IF=enp1s0
APPLIANCE_LAN_IF=enp2s0
APPLIANCE_LAN_CIDR=192.168.50.0/24
APPLIANCE_LAN_ADDRESS=192.168.50.1/24
APPLIANCE_LAN_GW=192.168.50.1
APPLIANCE_DNS_IP=192.168.50.1
APPLIANCE_MGMT_IP=192.168.50.1
APPLIANCE_DHCP_RANGE_START=192.168.50.50
APPLIANCE_DHCP_RANGE_END=192.168.50.250
APPLIANCE_DHCP_LEASE_HOURS=24
APPLIANCE_ALLOW_SSH=true
APPLIANCE_ENABLE_DNS_REDIRECT=true
APPLIANCE_BLOCK_DOT=true
